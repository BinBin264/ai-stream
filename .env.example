APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3100
API_PREFIX=/api
SECRET_KEY=change-me

BACKEND_PORT=8100
FRONTEND_PORT=3100

DATABASE_URL=postgresql+asyncpg://stream_user:stream_password@postgres:5432/stream_db
POSTGRES_DB=stream_db
POSTGRES_USER=stream_user
POSTGRES_PASSWORD=stream_password

REDIS_URL=redis://redis:6379/0

META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v23.0
META_REDIRECT_URI=http://localhost:8100/api/facebook/oauth/callback
META_VERIFY_TOKEN=change-me-verify-token
META_WEBHOOK_SECRET=
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
FACEBOOK_ENABLED=false
WEBHOOK_SIGNATURE_REQUIRED=false

PANCAKE_POS_BASE_URL=https://pos.pages.fm/api/v1

OPENAI_API_KEY=
OPENAI_COMMENT_MODEL=
OPENAI_STRATEGY_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MODERATION_MODEL=
OPENAI_TTS_MODEL=
OPENAI_STORE_RESPONSES=false

TOKEN_ENCRYPTION_KEY=
PII_HASH_SALT=change-me-local-salt

DEFAULT_RESERVATION_TTL_MINUTES=10
MAX_ORDER_QUANTITY_PER_ITEM=10
ORDER_HIGH_VALUE_REVIEW_THRESHOLD_VND=3000000
LOW_STOCK_THRESHOLD=3

AI_ENABLED=true
AI_AUTO_REPLY_ENABLED=false
AI_SPEECH_ENABLED=true
AI_HUMAN_HANDOVER_CONFIDENCE_THRESHOLD=0.75
AI_MAX_REPLY_LENGTH=300
AI_AVATAR_BASE_URL=
AI_AVATAR_API_TOKEN=

MEDIA_ENABLED=true
MEDIA_PROVIDER=ffmpeg
MEDIA_RENDER_PROVIDER=local
MEDIA_RENDER_BASE_URL=
MEDIA_RENDER_API_TOKEN=
DEFAULT_RENDER_PROFILE_ID=00000000-0000-0000-0000-000000000701

TTS_PROVIDER=fake
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

AVATAR_RUNTIME_PROVIDER=fake
AVATAR_RUNTIME_BASE_URL=
AVATAR_RUNTIME_API_TOKEN=

RTMP_OUTPUT_ENABLED=false
RTMPS_URL=
RTMPS_STREAM_KEY=
IDLE_VIDEO_PATH=/app/avatars/model_01/idle_base.mp4

STREAM_COMMENTS=stream:comments
STREAM_SPEECH=stream:speech
STREAM_AVATAR=stream:avatar
STREAM_PLAYOUT=stream:playout
REDIS_GROUP_COMMENTS=comment-workers
REDIS_GROUP_SPEECH=speech-workers
REDIS_GROUP_AVATAR=avatar-workers
REDIS_GROUP_PLAYOUT=playout-workers

MEDIA_OUTPUT_DIR=/app/media

LOG_LEVEL=info
OTEL_ENABLED=false

# ── Phase 2: Talking-Head POC ─────────────────────────────────────────────────
# MuseTalk CLI mode (Phase 2 default)
AVATAR_RUNTIME_MODE=cli
MUSETALK_HOME=/opt/musetalk
MUSETALK_PYTHON=python
MUSETALK_COMMAND_TEMPLATE=

# Output directories (relative to backend/)
AVATAR_OUTPUT_DIR=media/renders
AVATAR_AUDIO_DIR=media/audio

# Render defaults
AVATAR_FPS=25
AVATAR_RESOLUTION=1080x1920

# TTS provider: fake (local silent WAV) | vietnamese (requires edge-tts or gtts)
# TTS_PROVIDER=fake
TTS_LANGUAGE=vi
TTS_VOICE_ID=vi-VN-HoaiMyNeural
TTS_API_KEY=

# FFmpeg/FFprobe binaries (set if not on PATH)
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# ── Local Playout Program Assembly ────────────────────────────────────────────
PLAYOUT_MEDIA_ROOT=media/playout
PLAYOUT_MANIFEST_DIR=media/playout/manifests
PLAYOUT_NORMALIZED_DIR=media/playout/normalized
PLAYOUT_PROGRAM_DIR=media/playout/programs
PLAYOUT_TARGET_WIDTH=1080
PLAYOUT_TARGET_HEIGHT=1920
PLAYOUT_TARGET_FPS=25
PLAYOUT_TARGET_VIDEO_CODEC=libx264
PLAYOUT_TARGET_AUDIO_CODEC=aac
PLAYOUT_TARGET_PIXEL_FORMAT=yuv420p
PLAYOUT_TARGET_AUDIO_RATE=48000
PLAYOUT_TARGET_AUDIO_CHANNELS=2
PLAYOUT_DEFAULT_IDLE_LEAD_SECONDS=8
PLAYOUT_DEFAULT_IDLE_BETWEEN_SECONDS=10
PLAYOUT_DEFAULT_IDLE_TAIL_SECONDS=10
PLAYOUT_DEFAULT_TRANSITION=cut
PLAYOUT_MAX_TARGET_DURATION_SECONDS=180
PLAYOUT_RUNTIME_ENABLED=true
PLAYOUT_RUNTIME_OUTPUT_MODE=local_preview
PLAYOUT_VIDEO_CODEC=libx264
PLAYOUT_AUDIO_CODEC=aac
PLAYOUT_PIXEL_FORMAT=yuv420p
PLAYOUT_AUDIO_SAMPLE_RATE=48000
PLAYOUT_AUDIO_CHANNELS=2
PLAYOUT_HLS_TIME_SECONDS=2
PLAYOUT_HLS_LIST_SIZE=10
PLAYOUT_HLS_DIRECTORY=playout/live
PLAYOUT_IDLE_TRANSITION_POLICY=next_loop_boundary
PLAYOUT_MAX_QUEUE_SIZE=50
PLAYOUT_MAX_RUNTIME_RESTARTS=2
PLAYOUT_RUNTIME_HEARTBEAT_SECONDS=5
PLAYOUT_SEGMENT_MAX_DURATION_SECONDS=30
PLAYOUT_SESSION_CONTROL_STREAM=playout.session.control
PLAYOUT_SEGMENT_READY_STREAM=playout.segment.ready
PLAYOUT_SEGMENT_FAILED_STREAM=playout.segment.failed
PLAYOUT_RUNTIME_EVENTS_STREAM=playout.runtime.events
PLAYOUT_RUNTIME_CONSUMER_GROUP=dynamic-playout-workers
