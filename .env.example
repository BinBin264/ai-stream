APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3100
API_PREFIX=/api
SECRET_KEY=change-me

BACKEND_PORT=8100
FRONTEND_PORT=3100

DATABASE_URL=postgresql+asyncpg://stream_user:stream_password@postgres:5432/stream_db
POSTGRES_DB=stream_db
POSTGRES_USER=stream_user
POSTGRES_PASSWORD=stream_password

REDIS_URL=redis://redis:6379/0

META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v23.0
META_REDIRECT_URI=http://localhost:8100/api/facebook/oauth/callback
META_VERIFY_TOKEN=change-me-verify-token
META_WEBHOOK_SECRET=
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
FACEBOOK_ENABLED=false
WEBHOOK_SIGNATURE_REQUIRED=false

# Pancake POS product catalog sync
PANCAKE_POS_BASE_URL=https://pos.pages.fm/api/v1

OPENAI_API_KEY=
OPENAI_COMMENT_MODEL=
OPENAI_STRATEGY_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MODERATION_MODEL=
OPENAI_TTS_MODEL=
OPENAI_STORE_RESPONSES=false

TOKEN_ENCRYPTION_KEY=
PII_HASH_SALT=change-me-local-salt

DEFAULT_RESERVATION_TTL_MINUTES=10
MAX_ORDER_QUANTITY_PER_ITEM=10
ORDER_HIGH_VALUE_REVIEW_THRESHOLD_VND=3000000
LOW_STOCK_THRESHOLD=3

AI_ENABLED=true
AI_AUTO_REPLY_ENABLED=true
AI_SPEECH_ENABLED=false
AI_HUMAN_HANDOVER_CONFIDENCE_THRESHOLD=0.75
AI_MAX_REPLY_LENGTH=300
AI_AVATAR_BASE_URL=http://host.docker.internal:8000
AI_AVATAR_API_TOKEN=

MEDIA_ENABLED=false
MEDIA_PROVIDER=ffmpeg
MEDIA_RENDER_PROVIDER=modal
MEDIA_RENDER_BASE_URL=
MEDIA_RENDER_API_TOKEN=
DEFAULT_RENDER_PROFILE_ID=00000000-0000-0000-0000-000000000701
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
RTMP_OUTPUT_ENABLED=false
# Manual RTMPS fallback. If FACEBOOK_ENABLED=true, Graph API create_live_video
# should return stream URL/key automatically.
RTMPS_URL=
RTMPS_STREAM_KEY=
IDLE_VIDEO_PATH=/app/media/idle.mp4

LOG_LEVEL=info
OTEL_ENABLED=false
SENTRY_DSN=
